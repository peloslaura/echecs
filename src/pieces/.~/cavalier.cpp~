#include "cavalier.hpp"
#include "piece.hpp"
#include "square.hpp"
#include <cmath> // Pour abs()

using namespace std;

// Constructeur
Cavalier::Cavalier(string couleur, string nom, int id, Square position)
    : Piece(couleur, nom, id, position) {}

// Destructeur
Cavalier::~Cavalier() {}

// Vérification du mouvement légal
bool Cavalier::est_mouvement_legal(Square case_origine, Square case_destination) const {
    int delta_ligne = abs(case_destination.get_ligne() - case_origine.get_ligne());
    int delta_col = abs(case_destination.get_colonne() - case_origine.get_colonne());

    // Le cavalier se déplace en L : (2,1) ou (1,2)
    bool mouvement_en_L = (delta_ligne == 2 && delta_col == 1) || 
                         (delta_ligne == 1 && delta_col == 2);

    if (!mouvement_en_L) {
        return false;
    }

    // Vérification de la prise
    if (case_destination.est_occupee()) {
        return case_destination.get_piece()->get_couleur() != this->get_couleur();
    }

    return true;
}