#include <iostream>
#include <vector>
#include <string>
#include <stdexcept>
#include "echiquier.hpp"
#include "piece.hpp"
#include "cavalier.hpp"
#include "pion.hpp"
#include "tour.hpp"
#include "fou.hpp"
#include "reine.hpp"
#include "roi.hpp"
#include "square.hpp"

using namespace std;

// Allocation mémoire pour l'échiquier
void Echiquier::alloc_mem_echiquier() {
    echiquier = new Piece**[8];
    for(int i = 0; i < 8; i++) {
        echiquier[i] = new Piece*[8];
        for(int j = 0; j < 8; j++) {
            echiquier[i][j] = nullptr; // Initialisation à nullptr
        }
    }
}

// Constructeur
Echiquier::Echiquier() {
    alloc_mem_echiquier();
    
    // Création des pièces blanches
    pieces[Blanc] = {
        new Tour(Blanc, "♖", 0, Square(0,0)),
        new Cavalier(Blanc, "♘", 1, Square(0,1)),
        new Fou(Blanc, "♗", 2, Square(0,2)),
        new Reine(Blanc, "♕", 3, Square(0,3)),
        new Roi(Blanc, "♔", 4, Square(0,4)),
        new Fou(Blanc, "♗", 5, Square(0,5)),
        new Cavalier(Blanc, "♘", 6, Square(0,6)),
        new Tour(Blanc, "♖", 7, Square(0,7))
    };
    
    // Création des pièces noires
    pieces[Noir] = {
        new Tour(Noir, "♜", 8, Square(7,0)),
        new Cavalier(Noir, "♞", 9, Square(7,1)),
        new Fou(Noir, "♝", 10, Square(7,2)),
        new Reine(Noir, "♛", 11, Square(7,3)),
        new Roi(Noir, "♚", 12, Square(7,4)),
        new Fou(Noir, "♝", 13, Square(7,5)),
        new Cavalier(Noir, "♞", 14, Square(7,6)),
        new Tour(Noir, "♜", 15, Square(7,7))
    };
    
    // Création des pions
    for(int i = 0; i < 8; i++) {
        pieces[Blanc].push_back(new Pion(Blanc, "♙", 16+i, Square(1,i)));
        pieces[Noir].push_back(new Pion(Noir, "♟", 24+i, Square(6,i)));
    }
    
    // Placement des pièces sur l'échiquier
    for(auto p : pieces[Blanc]) {
        pose_piece(p, p->get_position());
    }
    for(auto p : pieces[Noir]) {
        pose_piece(p, p->get_position());
    }
}

// Affichage de l'échiquier
void Echiquier::affiche() const {
    string space5 = string(5, ' ');
    cout << endl;
    cout << "     a     b     c     d     e     f     g     h    " << endl;
    cout << "  +-----+-----+-----+-----+-----+-----+-----+-----+" << endl;
    
    for(int i = 7; i >= 0; i--) {
        cout << i+1 << " "; // numérotation ligne
        for(int j = 0; j < 8; j++) {
            cout << "|";
            if(echiquier[i][j]) {
                cout << "  ";
                echiquier[i][j]->affiche();
                cout << "  ";
            }
            else {
                cout << space5;
            }
        }
        cout << "|\n  +-----+-----+-----+-----+-----+-----+-----+-----+" << endl;
    }
}

// Récupération d'une pièce
Piece* Echiquier::get_piece(Square s) const {
    int ligne = s.get_ligne();
    int colonne = s.get_colonne();

    if(ligne < 0 || ligne >= 8 || colonne < 0 || colonne >= 8) {
        throw out_of_range("Coordonnées en dehors de l'échiquier");
    }

    return echiquier[ligne][colonne];
}