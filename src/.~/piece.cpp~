#include <iostream>
#include <string>
#include "piece.hpp"  // On inclut le header correspondant

// Constructeur paramétré
Piece::Piece(std::string c, std::string n, int i, Square pos)
    : couleur(c), nom(n), id(i), position(pos)  // Liste d'initialisation
{
}

void Piece::affiche()
{
    std::cout << nom << std::endl;
}

void Piece::get_position()
{
    std::cout << position.to_string() << std::endl;
}

void Piece::get_couleur()
{
    std::cout << couleur << std::endl;
}
