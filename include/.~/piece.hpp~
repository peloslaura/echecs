#ifndef PIECE_HPP
#define PIECE_HPP

#include <string>
#include "square.hpp"

class Piece {
public:
    // Constructeur paramétré
    Piece(std::string c, std::string n, int i, Square pos);
    void affiche();
    void get_position();
    void get_couleur();
    virtual bool est_mouvement_legal(Square case_origine, Square case_destination) const = 0;
private:
    std::string couleur;
    std::string nom;
    int id;
    Square position;
};

